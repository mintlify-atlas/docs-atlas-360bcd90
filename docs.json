{
  "$schema": "https://mintlify.com/docs.json",
  "name": "tldr-pages",
  "theme": "palm",
  "colors": {
    "primary": "#233453",
    "light": "#72b3aa",
    "dark": "#3c646c"
  },
  "favicon": "https://media.brand.dev/4fe77fc8-ec04-476a-966b-8a4cb47cf545.png",
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/tldr-pages/tldr"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/tldr-pages/tldr"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "clients"
            ]
          },
          {
            "group": "Contributing",
            "pages": [
              "contributing/overview",
              "contributing/style-guide",
              "contributing/page-format",
              "contributing/translations",
              "contributing/submitting-a-pr"
            ]
          },
          {
            "group": "Page Structure",
            "pages": [
              "pages/anatomy",
              "pages/placeholders",
              "pages/platforms",
              "pages/subcommands"
            ]
          },
          {
            "group": "Community",
            "pages": [
              "community/governance",
              "community/roles",
              "community/maintainers-guide"
            ]
          }
        ]
      },
      {
        "tab": "Client Specification",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "spec/overview",
              "spec/cli-interface"
            ]
          },
          {
            "group": "Page Resolution",
            "pages": [
              "spec/page-resolution",
              "spec/language",
              "spec/caching"
            ]
          }
        ]
      }
    ]
  }
}
